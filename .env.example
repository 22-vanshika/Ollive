# ─── Frontend ──────────────────────────────────────────────────────────────────
# Backend API base URL (no trailing slash)
# Development: http://localhost:8000
VITE_API_BASE_URL=http://localhost:8000

# ─── Backend ───────────────────────────────────────────────────────────────────

# Environment: development | staging | production
APP_ENV=development

# Uvicorn bind settings
APP_HOST=0.0.0.0
APP_PORT=8000

# Log level: DEBUG | INFO | WARNING | ERROR
LOG_LEVEL=INFO

# JSON array of allowed CORS origins (pydantic-settings v2 list format)
# Development: ["http://localhost:5173"]
CORS_ORIGINS=["http://localhost:5173"]

# ─── Database (Supabase / PostgreSQL) ──────────────────────────────────────────
# Async SQLAlchemy connection string
# Format: postgresql+asyncpg://<user>:<password>@<host>:<port>/<dbname>
# Obtain from: Supabase dashboard → Project Settings → Database → Connection string
DATABASE_URL=postgresql+asyncpg://postgres:password@db.xxxx.supabase.co:5432/postgres

# ─── LLM Provider ──────────────────────────────────────────────────────────────
# Groq API key — obtain from https://console.groq.com/keys
GROQ_API_KEY=gsk_...
